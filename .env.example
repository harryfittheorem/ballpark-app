# ============================================
# Ballpark Athlete App — Environment Variables
# ============================================
# In Replit, these are set via Tools → Secrets, NOT via .env files.
# This file is just a reference for what keys to add.

# --------------------------------------------
# Supabase (required for v0.1)
# --------------------------------------------
# Get these from: https://supabase.com/dashboard/project/_/settings/api
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# --------------------------------------------
# Tenant context (required for v0.1)
# --------------------------------------------
# For now, hardcoded to Infinite Hitting.
# Future: per-tenant builds via EAS profiles.
EXPO_PUBLIC_TENANT_SLUG=infinitehitting

# --------------------------------------------
# Stripe (required for v0.5)
# --------------------------------------------
# Use test keys until pilot launch
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_

# --------------------------------------------
# Server-side secrets — these go in BOTH places:
# 1. Replit Secrets (for local dev / scripts)
# 2. Supabase dashboard → Edge Functions → Secrets (for prod)
# --------------------------------------------
# Stripe secret (server)
# STRIPE_SECRET_KEY=sk_test_

# Mux (server)
# MUX_TOKEN_ID=
# MUX_TOKEN_SECRET=
# MUX_WEBHOOK_SECRET=

# Twilio (server, for v0.6+)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=

# Resend (server, for v0.3+)
# RESEND_API_KEY=

# Anthropic (server, for AI Layer in later phase)
# ANTHROPIC_API_KEY=

# --------------------------------------------
# Replit-specific notes:
# --------------------------------------------
# - Variables prefixed with EXPO_PUBLIC_ are bundled into the mobile app
# - Anything else is server-side only (used in Edge Functions)
# - To access in code: process.env.EXPO_PUBLIC_SUPABASE_URL
# - All workspace developers share the same Secrets
